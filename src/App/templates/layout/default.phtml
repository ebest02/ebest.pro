    <script>
        // Gestion explicite du menu mobile (hamburger) pour garantir le fonctionnement partout
        document.addEventListener('DOMContentLoaded', function () {
            var toggler   = document.querySelector('#navbar-main .navbar-toggler');
            var target    = document.getElementById('navbar_global');
            var closeLink = document.querySelector('.collapse-close a[data-target="#navbar_global"]');

            if (toggler && target) {
                toggler.addEventListener('click', function (e) {
                    e.preventDefault();
                    var isShown = target.classList.contains('show');
                    target.classList.toggle('show', !isShown);
                    toggler.setAttribute('aria-expanded', String(!isShown));
                });
            }

            if (closeLink && target) {
                closeLink.addEventListener('click', function (e) {
                    e.preventDefault();
                    target.classList.remove('show');
                    if (toggler) {
                        toggler.setAttribute('aria-expanded', 'false');
                    }
                });
            }
        });
    </script>

