<script>
(function() {
    // Fonction pour afficher une image
    function showImage(img, siteId) {
        if (img.getAttribute('data-shown') === 'true') return; // Déjà affichée
        img.style.opacity = '1';
        img.setAttribute('data-shown', 'true');
        const spinner = document.getElementById(siteId + '-spinner');
        if (spinner) spinner.style.display = 'none';
    }
    
    // Fonction pour vérifier si une image est chargée
    function isImageLoaded(img) {
        return img.complete && 
               img.naturalHeight !== 0 && 
               img.naturalWidth !== 0 &&
               img.naturalWidth > 0 && 
               img.naturalHeight > 0;
    }
    
    // Fonction pour initialiser les vignettes
    function initializeScreenshots() {
        document.querySelectorAll('.screenshot-img').forEach(img => {
            const siteId = img.getAttribute('data-site-id');
            if (siteId) {
                // Vérifier si l'image est déjà chargée (plusieurs méthodes)
                if (isImageLoaded(img)) {
                    showImage(img, siteId);
                } else {
                    // Attacher un gestionnaire onload si pas déjà fait
                    if (!img.hasAttribute('data-initialized')) {
                        img.setAttribute('data-initialized', 'true');
                        
                        // Gestionnaire onload
                        img.addEventListener('load', function() {
                            showImage(this, this.getAttribute('data-site-id'));
                        });
                        
                        // Gestionnaire onerror
                        img.addEventListener('error', function() {
                            console.error('Erreur chargement vignette:', this.src);
                            const retries = parseInt(this.getAttribute('data-retries') || '0');
                            if (retries < 3) {
                                this.setAttribute('data-retries', (retries + 1).toString());
                                this.src = '/api/screenshot?url=' + encodeURIComponent(this.getAttribute('data-url')) + '&t=' + Date.now() + '&nocache=1';
                            }
                        });
                    }
                    
                    // Vérifier périodiquement si l'image est chargée (pour les images en cache)
                    setTimeout(() => {
                        if (isImageLoaded(img) && img.getAttribute('data-shown') !== 'true') {
                            showImage(img, siteId);
                        }
                    }, 100);
                }
            }
        });
    }
    
    // Initialiser au chargement de la page
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeScreenshots);
    } else {
        initializeScreenshots();
    }
    
    // Réinitialiser après plusieurs délais pour les images qui se chargent lentement
    setTimeout(initializeScreenshots, 500);
    setTimeout(initializeScreenshots, 1000);
    setTimeout(initializeScreenshots, 2000);
    
    // Observer pour les nouvelles images ajoutées dynamiquement
    const observer = new MutationObserver(() => {
        initializeScreenshots();
    });
    
    observer.observe(document.body, { childList: true, subtree: true });
})();
</script>
<?php $this->stop() ?>

