const CAT_COLORS = {Network:"#5b7fa6",Forensics:"#5a9e82",Password:"#c49a3a",Reverse:"#7b6fc4",Web:"#b85c7a",Exploitation:"#c05555",OSINT:"#4a7ab5",Crypto:"#6a9930",Anonymat:"#7a7a7a",DevOps:"#3a8f9f",IA:"#9b59b6",Backup:"#2e86ab"};
const CATS = ["Network","Forensics","Password","Reverse","Web","Exploitation","OSINT","Crypto","Anonymat","DevOps","IA","Backup"];

let activeFilter = "Tous";
let expanded = new Set();

function render() {
  const q = document.getElementById("search").value.toLowerCase();
  const filtered = TOOLS.filter(t =>
    (activeFilter === "Tous" || t.cat === activeFilter) &&
    (!q || t.name.toLowerCase().includes(q) || t.desc.toLowerCase().includes(q))
  );
  document.getElementById("hcount").textContent = filtered.length + " outils";
  document.getElementById("stats").innerHTML = [
    {n:TOOLS.length,l:"Total"},
    {n:TOOLS.filter(t=>t.status==="ok").length,l:"Installés"},
    {n:TOOLS.filter(t=>t.status!=="ok").length,l:"À installer"},
    {n:CATS.length,l:"Catégories"}
  ].map(s=>`<div class="stat"><div class="stat-n">${s.n}</div><div class="stat-l">${s.l}</div></div>`).join("");

  document.getElementById("sidebar").innerHTML =
    `<button class="cat-btn ${activeFilter==="Tous"?"active":""}" onclick="setFilter('Tous')">
      <span class="cat-dot" style="background:var(--accent)"></span>
      <span class="cat-label">Tous</span>
      <span class="cat-count">${TOOLS.length}</span>
    </button>` +
    CATS.map(c => {
      const n = TOOLS.filter(t=>t.cat===c).length;
      return `<button class="cat-btn ${activeFilter===c?"active":""}" onclick="setFilter('${c}')">
        <span class="cat-dot" style="background:${CAT_COLORS[c]}"></span>
        <span class="cat-label">${c}</span>
        <span class="cat-count">${n}</span>
      </button>`;
    }).join("");

  const contentEl = document.getElementById("content");
  if (!filtered.length) {
    contentEl.innerHTML = `<div class="no-results">Aucun outil trouvé pour votre recherche.</div>`;
    return;
  }

  contentEl.innerHTML = CATS.map(cat => {
    const tools = filtered.filter(t=>t.cat===cat);
    if (!tools.length) return "";
    return `<div class="cat-section">
      <div class="cat-header">
        <span class="cat-dot" style="background:${CAT_COLORS[cat]};width:10px;height:10px;box-shadow:2px 2px 5px rgba(0,0,0,0.2)"></span>
        <span class="cat-name">${cat}</span>
        <span class="cat-badge">${tools.length} outil${tools.length>1?"s":""}</span>
      </div>
      <div class="tools-grid">
        ${tools.map(t => `
          <div class="tool-card ${expanded.has(t.name)?"open":""}" onclick="toggle('${t.name}')">
            <div class="tool-top">
              <span class="tool-dot2" style="background:${CAT_COLORS[t.cat]}"></span>
              <span class="tool-name">${t.name}</span>
              <span class="tool-badge ${t.status==="ok"?"badge-ok":"badge-warn"}">${t.status==="ok"?"Installé":"À installer"}</span>
              <span class="tool-arrow">&#9658;</span>
            </div>
            <div class="tool-body">
              <div class="tool-divider"></div>
              <p class="tool-desc">${t.desc}</p>
              <div class="example-label">Exemple d usage</div>
              <div class="example-code">${t.example}</div>
            </div>
          </div>
        `).join("")}
      </div>
    </div>`;
  }).join("");
}

function setFilter(cat) { activeFilter = cat; render(); }
function toggle(name) { expanded.has(name) ? expanded.delete(name) : expanded.add(name); render(); }
render();
</script>