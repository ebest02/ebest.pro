<script>
(function() {
    var btn = document.getElementById('palindromes-anim-toggle');
    var container = document.getElementById('palindromes-3d-container');
    if (btn && container) {
        btn.addEventListener('click', function() {
            var paused = container.classList.toggle('palindromes-anim-paused');
            btn.setAttribute('aria-pressed', paused ? 'true' : 'false');
            btn.textContent = paused ? 'Lancer l\'animation' : 'Arrêter l\'animation';
        });
    }
    var form = document.getElementById('palindromes-generate-form');
    var overlay = document.getElementById('palindromes-generating-overlay');
    var generateBtn = document.getElementById('palindromes-generate-btn');
    if (form && overlay) {
        form.addEventListener('submit', function() {
            if (generateBtn) generateBtn.disabled = true;
            overlay.classList.add('is-active');
            overlay.setAttribute('aria-hidden', 'false');
        });
    }
})();
</script>

